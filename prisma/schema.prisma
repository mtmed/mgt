// Prisma-Schema für bada bup — Kernschleife (DESIGN_DECISIONS.md).
// Bezeichner englisch, UI deutsch. Register (Fach/Pause) und Typ (Fall/Info)
// werden aus `intent` abgeleitet — nicht redundant gespeichert.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Intent {
  SEEK // Input holen (Frage/Fall) — Fach-Register, als gelöst markierbar
  GIVE // Input geben (Info)       — Fach-Register, kann Quelle tragen
  PAUSE // Pause                    — Pause-Register, kein Gelb, keine Zahl
}

enum PostStatus {
  OPEN // offen
  SOLVED // gelöst (setzt nur der/die Fragende)
}

enum SourceRelation {
  MATCHES // deckt sich
  EXCEEDS // geht darüber hinaus
  DIVERGES // weicht bewusst ab (Grund Pflicht)
}

model User {
  id             String          @id @default(cuid())
  name           String
  role           String // z. B. "Arbeitsmediziner:in"
  approved       Boolean         @default(false) // manuelle Freischaltung (MVP)
  createdAt      DateTime        @default(now())
  posts          Post[]
  answers        Answer[]
  endorsements   Endorsement[]
  pauseReactions PauseReaction[]
}

model Post {
  id             String          @id @default(cuid())
  intent         Intent
  status         PostStatus      @default(OPEN)
  isPseudonym    Boolean         @default(false) // nur bei SEEK erlaubt
  title          String? // Pflicht für Fach (SEEK/GIVE), keiner im Pause-Register
  text           String
  author         User            @relation(fields: [authorId], references: [id])
  authorId       String
  answers        Answer[]
  endorsements   Endorsement[]
  sources        Source[]
  pauseReactions PauseReaction[]
  tags           PostTag[]
  attachments    Attachment[]
  createdAt      DateTime        @default(now())
}

// Bild-Anhang (nicht-personenbezogen). EXIF wird beim Upload entfernt.
model Attachment {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  url       String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

enum TagCategory {
  VORSORGE // G-Grundsätze (G20, G25, G37 …)
  THEMA // Themenfelder (Impfen, Mutterschutz …)
}

model Tag {
  id        String       @id @default(cuid())
  slug      String       @unique
  label     String
  category  TagCategory? // null = von Nutzer:in vorgeschlagen, noch ohne Einordnung
  approved  Boolean      @default(true) // kuratiert = true; Vorschläge = false (Admin gibt frei)
  createdAt DateTime     @default(now())
  posts     PostTag[]
}

// Editierbare UI-Beschriftungen (Admin pflegt sie; Fallback = Default im Code).
model Label {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// n:m zwischen Post und Tag (kuratierte/hybride Verschlagwortung).
model PostTag {
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
}

model Answer {
  id           String        @id @default(cuid())
  text         String
  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId       String
  author       User          @relation(fields: [authorId], references: [id]) // immer namentlich
  authorId     String
  endorsements Endorsement[]
  createdAt    DateTime      @default(now())
}

// „würde ich genauso machen" — Ziel ist ein Info-Post ODER eine Answer.
// NUR aggregiert auslesen (Konsens-Band), nie namentlich.
model Endorsement {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String?
  answer    Answer?  @relation(fields: [answerId], references: [id], onDelete: Cascade)
  answerId  String?
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@unique([userId, answerId])
}

model Source {
  id        String         @id @default(cuid())
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  title     String
  url       String? // optionaler Link
  relation  SourceRelation
  reason    String? // Pflicht bei DIVERGES (in der Validierung erzwungen)
  createdAt DateTime       @default(now())
}

// „haben geschmunzelt" — Gesichter, keine Zahl, kein Gelb. Off the record.
model PauseReaction {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}
