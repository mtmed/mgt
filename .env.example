# Neon Postgres (EU/Frankfurt) — Verbindungs-URL aus dem Neon-Dashboard.
# Lokal in .env eintragen (wird NICHT committet). In Vercel als Environment-Variable setzen.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Admin-Account: E-Mail-Adresse, die beim Login automatisch Moderationsrechte
# (admin + approved) erhält. Dedizierter Account — kein Passwort-Gate mehr.
# Auch in Vercel setzen.
ADMIN_EMAIL="admin@example.com"

# Vercel Blob (Bild-Anhänge). Token aus dem Vercel-Blob-Store; in Vercel automatisch
# gesetzt, sobald der Store mit dem Projekt verbunden ist. Lokal aus dem Dashboard kopieren.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Auth.js (NextAuth v5) — Magic-Link-Login via Resend.
# AUTH_SECRET: zufälliger String (z. B. `openssl rand -base64 32`). In Vercel setzen.
# AUTH_RESEND_KEY: API-Key aus dem Resend-Dashboard.
# EMAIL_FROM: verifizierte Absenderadresse (Resend). Für Tests: onboarding@resend.dev.
AUTH_SECRET="change-me"
AUTH_RESEND_KEY="re_..."
EMAIL_FROM="bada bup <onboarding@resend.dev>"
