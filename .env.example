# Neon Postgres (EU/Frankfurt) — Verbindungs-URL aus dem Neon-Dashboard.
# Lokal in .env eintragen (wird NICHT committet). In Vercel als Environment-Variable setzen.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Admin-Gate: Passwort für /admin (auch in Vercel setzen).
ADMIN_PASSWORD="change-me"

# Vercel Blob (Bild-Anhänge). Token aus dem Vercel-Blob-Store; in Vercel automatisch
# gesetzt, sobald der Store mit dem Projekt verbunden ist. Lokal aus dem Dashboard kopieren.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
